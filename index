                        </ul>
                    </div>
                    
                    <div class="bg-white rounded-[1.8rem] shadow-soft border-l-[8px] border-red-400 p-7 fade-in h-full flex flex-col justify-center" style="animation-delay: 0.1s;">
                        <div class="flex items-center gap-2 mb-4">
                            <span class="text-2xl">⚠️</span><h4 class="font-black text-gray-800 text-[16px]">${t.aiTitles[1]}</h4>
                        </div>
                        <ul class="text-[14px] text-gray-600 space-y-3 pl-4 list-disc marker:text-red-400 font-medium leading-relaxed">
                            <li>${getWeak[0]}</li>
                            <li>${getWeak[1]}</li>
