                    </div>

                    <div class="bg-white rounded-[1.8rem] shadow-soft border-l-[8px] border-[#5AB2FF] p-7 fade-in h-full flex flex-col justify-center" style="animation-delay: 0.2s;">
                        <div class="flex items-center gap-2 mb-4">
