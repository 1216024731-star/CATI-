                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-12 gap-7">
                        <div class="lg:col-span-5 bg-white rounded-[2.5rem] p-10 shadow-soft border border-gray-100 flex flex-col items-center justify-center min-h-[500px]">
                            <div class="w-full text-left mb-6">
                                <h3 class="text-lg font-bold text-gray-800">${t.radarTitle}</h3>
                                <p class="text-[10px] text-gray-400 font-bold tracking-[0.2em] uppercase">${t.radarSubtitle}</p>
                            </div>
                            <div class="flex-1 w-full flex items-center justify-center">
                                <canvas id="radarCanvas" class="w-full max-w-[340px]"></canvas>
                            </div>
                        </div>

                        <div class="lg:col-span-7 flex flex-col gap-5 min-h-[500px] h-full" id="aiContainer">
                            <div class="bg-white rounded-[2.5rem] shadow-soft border border-gray-100 p-12 h-full flex flex-col items-center justify-center text-center">
                                <div class="spinner mb-6"></div>
                                <h3 class="font-bold text-gray-800 text-lg">正在连接 AI 分析模型</h3>
                                <p class="text-brand text-sm mt-2">${t.analyzing}</p>
                            </div>
