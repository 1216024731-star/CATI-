                    </div>

                    <div class="w-full flex justify-center pt-8">
                        <button onclick="reset()" class="bg-[#2D3748] hover:bg-[#1A202C] text-white font-bold py-4 md:py-5 px-14 md:px-20 rounded-full shadow-[0_12px_35px_-8px_rgba(45,55,72,0.4)] transition-all duration-300 text-lg md:text-xl active:scale-95 tracking-wide">
                            ${t.retake}
                        </button>
                    </div>
                </div>
            `;

            drawRadarChart();
            fetchGemini();
        }

        function drawRadarChart() {
            const canvas = document.getElementById('radarCanvas');
            if(!canvas) return;
            const ctx = canvas.getContext('2d');
            const size = 340;
            const dpr = window.devicePixelRatio || 1;
            canvas.width = size * dpr;
            canvas.height = size * dpr;
            canvas.style.width = size + 'px';
            ctx.scale(dpr, dpr);

            const center = size / 2;
            const radius = 105;
            const sides = 6;
            const labels = radarLabels[lang];
            const values = animalData[animalKey].stats;

            ctx.clearRect(0, 0, size, size);

            ctx.strokeStyle = '#F1F5F9';
            ctx.lineWidth = 1;
            for (let s = 1; s <= 4; s++) {
                let r = radius * (s / 4);
                ctx.beginPath();
                for (let i = 0; i < sides; i++) {
                    let a = (Math.PI * 2 * i) / sides - Math.PI / 2;
                    let x = center + r * Math.cos(a);
                    let y = center + r * Math.sin(a);
                    if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
                }
                ctx.closePath();
                ctx.stroke();
            }

            ctx.fillStyle = '#94A3B8';
            ctx.font = 'bold 10px Inter, sans-serif';
            ctx.textAlign = 'center';
            for (let i = 0; i < sides; i++) {
                let a = (Math.PI * 2 * i) / sides - Math.PI / 2;
                ctx.beginPath();
                ctx.moveTo(center, center);
                ctx.lineTo(center + radius * Math.cos(a), center + radius * Math.sin(a));
                ctx.stroke();
                let labelRadius = radius + 35;
                ctx.fillText(labels[i], center + labelRadius * Math.cos(a), center + labelRadius * Math.sin(a) + 4);
            }

            ctx.beginPath();
            for (let i = 0; i < sides; i++) {
                let a = (Math.PI * 2 * i) / sides - Math.PI / 2;
                let r = radius * (values[i] / 100);
                let x = center + r * Math.cos(a);
                let y = center + r * Math.sin(a);
                if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
            }
            ctx.closePath();
            ctx.fillStyle = 'rgba(102, 192, 177, 0.35)';
            ctx.fill();
            ctx.strokeStyle = '#66C0B1';
            ctx.lineWidth = 3;
            ctx.stroke();
        }

        // ====== 真正“千人千面”的动态长文本解析引擎 ======
        function fetchGemini() {
            const data = animalData[animalKey];
            const t = i18n[lang];

            const charE_I = animalKey.charAt(0);
            const charS_N = animalKey.charAt(1);
            const charT_F = animalKey.charAt(2);
            const charJ_P = animalKey.charAt(3);

            const strZh = {
