                            <p class="text-gray-400 text-xs font-bold tracking-widest uppercase mb-7">${t.resultSubtitle}</p>
                            
                            <blockquote class="text-lg md:text-2xl text-gray-600 border-l-[6px] border-blue-300 pl-5 mb-10 italic font-medium leading-relaxed tracking-tight transition-colors duration-300">
                                "${data.desc[lang]}"
                            </blockquote>
                            
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-[13px] text-gray-600 font-bold bg-gray-50/50 p-6 rounded-2xl border border-gray-100">
                                <div class="flex items-center gap-3"><span class="text-blue-500 text-lg font-black">✓</span> 独特的动物本能加持</div>
                                <div class="flex items-center gap-3"><span class="text-blue-500 text-lg font-black">✓</span> 深度契合的职场属性</div>
                                <div class="flex items-center gap-3"><span class="text-blue-500 text-lg font-black">✓</span> 已根据测试深度分析</div>
